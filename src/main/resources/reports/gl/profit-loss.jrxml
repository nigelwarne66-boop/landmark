<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="profit-loss"
              pageWidth="595" pageHeight="842" orientation="Portrait"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail">

  <parameter name="COMPANY_NO"    class="java.lang.Integer"/>
  <parameter name="YEAR_NO"       class="java.lang.Integer"/>
  <parameter name="COMPANY_NAME"  class="java.lang.String"/>
  <parameter name="YEAR_DESC"     class="java.lang.String"/>
  <parameter name="FROM_PERIOD"   class="java.lang.Integer">
    <defaultValueExpression><![CDATA[1]]></defaultValueExpression>
  </parameter>
  <parameter name="TO_PERIOD"     class="java.lang.Integer">
    <defaultValueExpression><![CDATA[12]]></defaultValueExpression>
  </parameter>

  <queryString>
    <![CDATA[
      SELECT
        a.acct_main_no,
        a.desc1,
        a.acct_type,
        CASE WHEN a.dr_cr_ind='C' AND a.pl_bs_ind='P' THEN 'Income' ELSE 'Expense' END AS section,
        COALESCE(SUM(t.cr_amt) - SUM(t.dr_amt), 0) AS amount
      FROM glchart a
      LEFT JOIN gltrx t ON t.company_no = a.company_no
                          AND t.acct_main_no = a.acct_main_no
                          AND t.sub_acct_no = a.acct_sub_no
                          AND t.year_no  = $P{YEAR_NO}
                          AND t.period_no BETWEEN $P{FROM_PERIOD} AND $P{TO_PERIOD}
      WHERE a.company_no = $P{COMPANY_NO}
        AND a.acct_type IN ('I','R','E','X')
      GROUP BY a.acct_main_no, a.desc1, a.acct_type, section
      HAVING amount <> 0
      ORDER BY section DESC, a.acct_main_no
    ]]>
  </queryString>

  <field name="acct_no"   class="java.lang.String"/>
  <field name="acct_desc" class="java.lang.String"/>
  <field name="acct_type" class="java.lang.String"/>
  <field name="section"   class="java.lang.String"/>
  <field name="amount"    class="java.math.BigDecimal"/>

  <variable name="INCOME_TOTAL"  class="java.math.BigDecimal" resetType="Report" calculation="Sum">
    <variableExpression><![CDATA[$F{section}.equals("Income") ? $F{amount} : java.math.BigDecimal.ZERO]]></variableExpression>
  </variable>
  <variable name="EXPENSE_TOTAL" class="java.math.BigDecimal" resetType="Report" calculation="Sum">
    <variableExpression><![CDATA[$F{section}.equals("Expense") ? $F{amount}.negate() : java.math.BigDecimal.ZERO]]></variableExpression>
  </variable>
  <variable name="SECTION_TOTAL" class="java.math.BigDecimal" resetType="Group" resetGroup="SectionGroup" calculation="Sum">
    <variableExpression><![CDATA[$F{amount}]]></variableExpression>
    <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
  </variable>

  <group name="SectionGroup">
    <groupExpression><![CDATA[$F{section}]]></groupExpression>
    <groupHeader>
      <band height="26">
        <rectangle>
          <reportElement x="0" y="4" width="535" height="20" backcolor="#e8edf5" forecolor="#e8edf5"/>
          <graphicElement><pen lineWidth="0"/></graphicElement>
        </rectangle>
        <textField>
          <reportElement x="4" y="6" width="300" height="16"/>
          <textElement><font size="10" isBold="true"/></textElement>
          <textFieldExpression><![CDATA[$F{section}.equals("Income") ? "INCOME" : "EXPENSES"]]></textFieldExpression>
        </textField>
      </band>
    </groupHeader>
    <groupFooter>
      <band height="22">
        <line>
          <reportElement x="380" y="2" width="155" height="1"/>
          <graphicElement><pen lineWidth="0.75" lineColor="#1e2d45"/></graphicElement>
        </line>
        <textField>
          <reportElement x="4" y="5" width="376" height="14"/>
          <textElement><font size="9" isBold="true"/></textElement>
          <textFieldExpression><![CDATA["Total " + $F{section}]]></textFieldExpression>
        </textField>
        <textField pattern="#,##0.00">
          <reportElement x="380" y="5" width="155" height="14"/>
          <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
          <textFieldExpression><![CDATA[$V{SECTION_TOTAL}]]></textFieldExpression>
        </textField>
      </band>
    </groupFooter>
  </group>

  <title>
    <band height="56">
      <staticText>
        <reportElement x="0" y="0" width="535" height="20"/>
        <textElement><font size="14" isBold="true"/></textElement>
        <text><![CDATA[Profit & Loss Statement]]></text>
      </staticText>
      <textField>
        <reportElement x="0" y="22" width="400" height="14"/>
        <textElement><font size="9"/></textElement>
        <textFieldExpression><![CDATA[$P{COMPANY_NAME} + "  —  " + $P{YEAR_DESC}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="36" width="400" height="14"/>
        <textElement><font size="9" isItalic="true"/></textElement>
        <textFieldExpression><![CDATA["Periods " + $P{FROM_PERIOD} + " to " + $P{TO_PERIOD}]]></textFieldExpression>
      </textField>
      <textField pattern="dd/MM/yyyy">
        <reportElement x="420" y="22" width="115" height="14"/>
        <textElement textAlignment="Right"><font size="9"/></textElement>
        <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <columnHeader>
    <band height="20">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="20" backcolor="#1e2d45" forecolor="#1e2d45"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <staticText><reportElement x="4"   y="4" width="70"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Account]]></text></staticText>
      <staticText><reportElement x="78"  y="4" width="298" height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Description]]></text></staticText>
      <staticText><reportElement x="380" y="4" width="155" height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[Amount]]></text></staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="16">
      <textField><reportElement x="4"   y="2" width="70"  height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{acct_no}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="78" y="2" width="298" height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{acct_desc}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00"><reportElement x="380" y="2" width="155" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{section}.equals("Income") ? $F{amount} : $F{amount}.negate()]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <summary>
    <band height="36">
      <line><reportElement x="0" y="2" width="535" height="1" forecolor="#1e2d45"/><graphicElement><pen lineWidth="1.5"/></graphicElement></line>
      <staticText><reportElement x="4" y="10" width="376" height="16"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[NET PROFIT / (LOSS)]]></text></staticText>
      <textField pattern="#,##0.00">
        <reportElement x="380" y="10" width="155" height="16"/>
        <textElement textAlignment="Right"><font size="11" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$V{INCOME_TOTAL}.subtract($V{EXPENSE_TOTAL})]]></textFieldExpression>
      </textField>
    </band>
  </summary>

</jasperReport>
