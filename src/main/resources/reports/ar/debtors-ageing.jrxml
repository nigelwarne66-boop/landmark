<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="debtors-ageing"
              pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="782" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail">

  <parameter name="COMPANY_NO"   class="java.lang.Integer"/>
  <parameter name="COMPANY_NAME" class="java.lang.String"/>
  <parameter name="AS_AT_DATE"   class="java.lang.String" isForPrompting="false"/>
  <parameter name="DATE_BASIS"   class="java.lang.String" isForPrompting="false"/>
  <parameter name="AMT_BASIS"    class="java.lang.String" isForPrompting="false"/>

  <!-- Data comes from a JRBeanCollectionDataSource — no queryString. -->

  <field name="custNo"   class="java.lang.String"/>
  <field name="name"     class="java.lang.String"/>
  <field name="location" class="java.lang.String"/>
  <field name="phone"    class="java.lang.String"/>
  <field name="p1"       class="java.math.BigDecimal"/>
  <field name="p2"       class="java.math.BigDecimal"/>
  <field name="p3"       class="java.math.BigDecimal"/>
  <field name="p4"       class="java.math.BigDecimal"/>
  <field name="p5"       class="java.math.BigDecimal"/>
  <field name="p6"       class="java.math.BigDecimal"/>
  <field name="total"    class="java.math.BigDecimal"/>

  <variable name="SUM_P1"    class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{p1}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
  <variable name="SUM_P2"    class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{p2}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
  <variable name="SUM_P3"    class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{p3}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
  <variable name="SUM_P4"    class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{p4}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
  <variable name="SUM_P5"    class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{p5}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
  <variable name="SUM_P6"    class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{p6}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
  <variable name="SUM_TOTAL" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{total}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
  <variable name="ROW_COUNT" class="java.lang.Integer"    calculation="Count"><variableExpression><![CDATA[$F{custNo}]]></variableExpression></variable>

  <title>
    <band height="56">
      <staticText><reportElement x="0" y="0" width="500" height="20"/><textElement><font size="13" isBold="true"/></textElement><text><![CDATA[Debtors Ageing]]></text></staticText>
      <textField><reportElement x="0" y="22" width="500" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$P{COMPANY_NAME}]]></textFieldExpression></textField>
      <textField><reportElement x="0" y="38" width="500" height="12"/><textElement><font size="8" isItalic="true"/></textElement><textFieldExpression><![CDATA["By " + $P{DATE_BASIS} + " — " + $P{AMT_BASIS}]]></textFieldExpression></textField>
      <staticText><reportElement x="600" y="22" width="80"  height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><text><![CDATA[As at:]]></text></staticText>
      <textField><reportElement x="682" y="22" width="100" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{AS_AT_DATE}]]></textFieldExpression></textField>
      <textField pattern="dd/MM/yyyy HH:mm"><reportElement x="600" y="38" width="182" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression></textField>
    </band>
  </title>

  <columnHeader>
    <band height="20">
      <rectangle><reportElement x="0" y="0" width="782" height="20" backcolor="#1e2d45"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="4"   y="4" width="40"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Cust]]></text></staticText>
      <staticText><reportElement x="46"  y="4" width="130" height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Name]]></text></staticText>
      <staticText><reportElement x="178" y="4" width="90"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Location]]></text></staticText>
      <staticText><reportElement x="270" y="4" width="70"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[Phone]]></text></staticText>
      <staticText><reportElement x="342" y="4" width="65"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[150+ days]]></text></staticText>
      <staticText><reportElement x="409" y="4" width="65"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[120 days]]></text></staticText>
      <staticText><reportElement x="476" y="4" width="65"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[90 days]]></text></staticText>
      <staticText><reportElement x="543" y="4" width="65"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[60 days]]></text></staticText>
      <staticText><reportElement x="610" y="4" width="65"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[30 days]]></text></staticText>
      <staticText><reportElement x="677" y="4" width="55"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[Current]]></text></staticText>
      <staticText><reportElement x="734" y="4" width="48"  height="12" forecolor="#ffffff" mode="Opaque" backcolor="#1e2d45"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[Total]]></text></staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="14">
      <textField><reportElement x="4"   y="1" width="40"  height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{custNo}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="46" y="1" width="130" height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{name}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="178" y="1" width="90"  height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{location}]]></textFieldExpression></textField>
      <textField><reportElement x="270" y="1" width="70"  height="12"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA[$F{phone}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="342" y="1" width="65" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{p1}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="409" y="1" width="65" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{p2}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="476" y="1" width="65" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{p3}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="543" y="1" width="65" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{p4}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="610" y="1" width="65" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{p5}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="677" y="1" width="55" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{p6}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="734" y="1" width="48" height="12"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{total}]]></textFieldExpression></textField>
    </band>
  </detail>

  <pageFooter>
    <band height="16">
      <textField pattern="dd/MM/yyyy"><reportElement x="0" y="2" width="100" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression></textField>
      <textField><reportElement x="660" y="2" width="122" height="12"/><textElement textAlignment="Right"><font size="7"/></textElement><textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression></textField>
    </band>
  </pageFooter>

  <summary>
    <band height="30">
      <line><reportElement x="0" y="2" width="782" height="1" forecolor="#1e2d45"/><graphicElement><pen lineWidth="1"/></graphicElement></line>
      <textField><reportElement x="4" y="6" width="200" height="12"/><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{ROW_COUNT} + " customer(s)"]]></textFieldExpression></textField>
      <staticText><reportElement x="220" y="6" width="120" height="12"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[Total outstanding:]]></text></staticText>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="342" y="6" width="65" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{SUM_P1}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="409" y="6" width="65" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{SUM_P2}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="476" y="6" width="65" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{SUM_P3}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="543" y="6" width="65" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{SUM_P4}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="610" y="6" width="65" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{SUM_P5}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="677" y="6" width="55" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{SUM_P6}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00;(#,##0.00)"><reportElement x="734" y="6" width="48" height="12"/><textElement textAlignment="Right"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{SUM_TOTAL}]]></textFieldExpression></textField>
    </band>
  </summary>

</jasperReport>
