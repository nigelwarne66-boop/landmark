<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  Shared period-range selector. Include via:
    <fx:include fx:id="periodSelector" source="GlPeriodSelector.fxml"/>
  Outer controller can then read:
    @FXML private GlPeriodSelectorController periodSelectorController;
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.landmarksoftware.ui.reports.GlPeriodSelectorController"
      spacing="10">

    <HBox styleClass="sel-row" alignment="CENTER_LEFT" spacing="12">
        <Label text="Period from" styleClass="sel-label" minWidth="120"/>
        <ComboBox fx:id="fromPeriod" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

    <HBox styleClass="sel-row" alignment="CENTER_LEFT" spacing="12">
        <Label text="Period to" styleClass="sel-label" minWidth="120"/>
        <ComboBox fx:id="toPeriod" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

</VBox>
