<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.landmarksoftware.ui.reports.FaAssetRegisterController"
    styleClass="sel-root"
    prefWidth="560">

    <top>
        <VBox styleClass="sel-header">
            <Label text="Asset Register" styleClass="sel-title"/>
            <Label text="Full asset listing by group and location" styleClass="sel-sub"/>
            <VBox.margin><Insets top="20" right="24" bottom="16" left="24"/></VBox.margin>
        </VBox>
    </top>

    <!-- No selection fields — report runs for the whole year from session context. -->
    <center>
        <VBox styleClass="sel-body" spacing="14">
            <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
            <Label text="No additional selections needed — the report covers the current company and year."
                   styleClass="sel-label" wrapText="true"/>
        </VBox>
    </center>

    <bottom>
        <HBox styleClass="sel-footer" alignment="CENTER_RIGHT" spacing="10">
            <padding><Insets top="16" right="24" bottom="20" left="24"/></padding>
            <Button text="Cancel" styleClass="sel-btn-cancel" onAction="#onCancel"/>
            <Button text="Excel"  styleClass="sel-btn-excel"  onAction="#onExcel"/>
            <Button text="PDF"    styleClass="sel-btn-pdf"    onAction="#onPdf"/>
        </HBox>
    </bottom>

</BorderPane>
